# Database
DB_PASSWORD=strongpassword123
DB_CONNECTION_STRING=Host=postgres;Port=5432;Database=ecommerce;Username=postgres;Password=strongpassword123

# Redis
REDIS_CONNECTION_STRING=redis:6379

# JWT (minimum 32 characters)
JWT_SECRET=your-super-secret-key-minimum-32-characters-long!!
JWT_ISSUER=ecommerce-api
JWT_AUDIENCE=ecommerce-client

# Observability
SEQ_URL=http://seq:5341
LOKI_URL=http://loki:3100
JAEGER_ENDPOINT=http://jaeger:4317

# Admin seed (Phase 1.5)
ADMIN_EMAIL=admin@ecommerce.com
ADMIN_PASSWORD=Admin@123456

# Grafana
GRAFANA_PASSWORD=admin

# Security (optional, comma-separated browser origins allowed via CORS; empty = no cross-origin access)
CORS_ALLOWED_ORIGINS=

# MinIO (S3-compatible object storage for product images)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_BUCKET_NAME=product-images
